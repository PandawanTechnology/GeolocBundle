<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="PandawanTechnology\GeolocBundle\Entity\City"
            repository-class="PandawanTechnology\GeolocBundle\Repository\CityRepository">
        <unique-constraints>
            <unique-constraint columns="country_code,insee_code"/>
        </unique-constraints>

        <indexes>
            <index name="idx_country" columns="country_code"/>
        </indexes>

        <id name="id" type="integer" column="id">
            <generator/>
        </id>

        <field name="inseeCode" length="5" nullable="true"/>
        <field name="postCode" length="16"/>
        <field name="name"/>
        <field name="countryCode" length="2"/>

        <one-to-many field="streets" target-entity="PandawanTechnology\GeolocBundle\Entity\Street" mapped-by="city">
            <cascade>
                <cascade-all/>
            </cascade>
        </one-to-many>
    </entity>
</doctrine-mapping>
