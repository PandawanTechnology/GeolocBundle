<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="PandawanTechnology\GeolocBundle\Entity\Street"
            repository-class="PandawanTechnology\GeolocBundle\Repository\StreetRepository">
        <unique-constraints>
            <unique-constraint columns="city_id,name"/>
        </unique-constraints>

        <id name="id" type="integer" column="id">
            <generator/>
        </id>

        <field name="name"/>

        <one-to-many field="addresses" target-entity="PandawanTechnology\GeolocBundle\Entity\Address"
                     mapped-by="street">
            <cascade>
                <cascade-all/>
            </cascade>
        </one-to-many>

        <many-to-one field="city" target-entity="PandawanTechnology\GeolocBundle\Entity\City" inversed-by="streets">
            <join-column nullable="false" on-delete="CASCADE"/>
        </many-to-one>
    </entity>
</doctrine-mapping>
